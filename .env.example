# Copy this file to `.env.local` for local overrides.
# The repo defaults stay conservative even if you leave this file unset.

API_PORT=3000
WEB_PORT=5173

# Optional. Required only for GitHub issue ingestion, draft PR creation,
# PR comment sync, or explicit PR iterate flows.
GITHUB_TOKEN=

# Optional. Set this only for GitHub Enterprise or a non-default API root.
GITHUB_API_URL=
