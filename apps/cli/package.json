{
  "name": "@gdh/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "gdh": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "biome check .",
    "test": "vitest run"
  },
  "dependencies": {
    "@gdh/artifact-store": "workspace:*",
    "@gdh/domain": "workspace:*",
    "@gdh/policy-engine": "workspace:*",
    "@gdh/review-packets": "workspace:*",
    "@gdh/runner-codex": "workspace:*",
    "@gdh/shared": "workspace:*",
    "@gdh/verification": "workspace:*",
    "commander": "^14.0.3"
  }
}
