{
  "name": "@gdh/cli",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "description": "Governed Delivery Control Plane CLI.",
  "type": "module",
  "files": [
    "dist",
    "package.json"
  ],
  "bin": {
    "gdh": "dist/program.js"
  },
  "main": "dist/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "biome check .",
    "test": "vitest run"
  },
  "dependencies": {
    "@gdh/artifact-store": "workspace:*",
    "@gdh/evals": "workspace:*",
    "@gdh/domain": "workspace:*",
    "@gdh/github-adapter": "workspace:*",
    "@gdh/policy-engine": "workspace:*",
    "@gdh/review-packets": "workspace:*",
    "@gdh/runner-codex": "workspace:*",
    "@gdh/shared": "workspace:*",
    "@gdh/verification": "workspace:*",
    "commander": "^14.0.3"
  }
}
