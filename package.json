{
  "name": "gdh",
  "version": "1.0.0",
  "private": true,
  "description": "Codex-first governed delivery control plane v1 public-showcase workspace.",
  "license": "MIT",
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "bootstrap": "pnpm install --frozen-lockfile && tsx scripts/bootstrap.ts",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "pnpm lint:root && turbo run lint",
    "lint:links": "tsx scripts/lint-links.ts",
    "lint:root": "biome check .",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "benchmark:smoke": "pnpm gdh benchmark run smoke --ci-safe",
    "dev:api": "pnpm --filter @gdh/api dev",
    "dev:web": "pnpm --filter @gdh/web dev",
    "dashboard:dev": "turbo run dev --filter=@gdh/api --filter=@gdh/web",
    "demo:prepare": "pnpm build && tsx scripts/demo-prep.ts",
    "gdh": "node apps/cli/dist/program.js",
    "review:quick": "tsx scripts/review-quick.ts",
    "validate": "pnpm lint && pnpm lint:links && pnpm typecheck && pnpm test && pnpm build",
    "release:validate": "pnpm validate && pnpm benchmark:smoke",
    "release:package": "pnpm build && tsx scripts/package-release.ts",
    "release:v1": "pnpm release:validate && pnpm demo:prepare && pnpm release:package",
    "release:rc": "pnpm release:v1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tsx": "^4.21.0",
    "turbo": "^2.8.17",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
